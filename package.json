{
  "name": "happenings-community-design-system",
  "version": "0.1.0",
  "description": "Design system and UI prototype playground for hAppenings Community CIC",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "bun run build:registry && vite build",
    "preview": "vite preview",
    "build:registry": "esbuild registry/index.ts --bundle --format=esm --outfile=static/registry/bundle.js",
    "watch:registry": "esbuild registry/index.ts --bundle --format=esm --outfile=static/registry/bundle.js --watch",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "keywords": [
    "design-system",
    "holochain",
    "happenings",
    "svelte",
    "lit"
  ],
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "esbuild": "^0.25.0",
    "lit": "^3.2.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0"
  }
}
