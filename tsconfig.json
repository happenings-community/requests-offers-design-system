{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "useDefineForClassFields": false,
    "experimentalDecorators": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.svelte",
    ".svelte-kit/ambient.d.ts",
    ".svelte-kit/non-ambient.d.ts",
    ".svelte-kit/types/**/$types.d.ts"
  ]
}
